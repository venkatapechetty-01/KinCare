{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "SecretKey": "",
    "Issuer": "KinCareAPI",
    "Audience": "KinCareUsers",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Twilio": {
    "AccountSid": "",
    "AuthToken": "",
    "FromNumber": ""
  },
  "Firebase": {
    "CredentialPath": ""
  },
  "Stripe": {
    "SecretKey": "",
    "WebhookSecret": "",
    "StarterPriceId": "",
    "ProfessionalPriceId": "",
    "EnterprisePriceId": "",
    "TrialPeriodDays": 14
  },
  "UberHealth": {
    "ClientId": "",
    "ClientSecret": "",
    "BaseUrl": "https://api.uber.com",
    "TokenUrl": "https://login.uber.com/oauth/v2/token",
    "Scope": "uber.trips",
    "Audience": "https://api.uber.com",
    "OrganizationId": "",
    "WebhookSecret": ""
  },
  "UberBusiness": {
    "ClientId": "",
    "ClientSecret": "",
    "BaseUrl": "https://api.uber.com",
    "TokenUrl": "https://login.uber.com/oauth/v2/token",
    "Scope": "ride_requests",
    "Audience": "https://api.uber.com",
    "ProductId": "",
    "WebhookSecret": ""
  },
  "Broker": {
    "BaseUrl": "https://api.roundtriphealth.com",
    "ApiKey": "",
    "ClientId": "",
    "ClientSecret": "",
    "Audience": "https://api.roundtriphealth.com",
    "OrganizationId": "",
    "WebhookSecret": ""
  },
  "App": {
    "BaseUrl": "https://app.kincare.com"
  },
  "Splunk": {
    "HecUrl": "",
    "HecToken": ""
  },
  "GoogleMaps": {
    "ApiKey": ""
  },
  "IpRateLimit": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "POST:/api/auth/login",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "POST:/api/onboarding/register",
        "Period": "1m",
        "Limit": 3
      },
      {
        "Endpoint": "POST:/webhook/twilio",
        "Period": "1m",
        "Limit": 60
      },
      {
        "Endpoint": "POST:/api/rides/location",
        "Period": "5s",
        "Limit": 1
      },
      {
        "Endpoint": "*",
        "Period": "1s",
        "Limit": 30
      }
    ]
  },
  "Cors": {
    "AllowedOrigins": []
  }
}
