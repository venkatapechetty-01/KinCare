{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "${KINCARE_DB_CONNECTION_STRING}"
  },
  "Jwt": {
    "SecretKey": "${KINCARE_JWT_SECRET_KEY}",
    "Issuer": "KinCareAPI",
    "Audience": "KinCareUsers",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Twilio": {
    "AccountSid": "${TWILIO_ACCOUNT_SID}",
    "AuthToken": "${TWILIO_AUTH_TOKEN}",
    "FromNumber": "${TWILIO_FROM_NUMBER}"
  },
  "Firebase": {
    "CredentialPath": "${FIREBASE_CREDENTIAL_PATH}"
  },
  "Stripe": {
    "SecretKey": "${STRIPE_SECRET_KEY}",
    "WebhookSecret": "${STRIPE_WEBHOOK_SECRET}",
    "StarterPriceId": "${STRIPE_STARTER_PRICE_ID}",
    "ProfessionalPriceId": "${STRIPE_PROFESSIONAL_PRICE_ID}",
    "EnterprisePriceId": "${STRIPE_ENTERPRISE_PRICE_ID}",
    "TrialPeriodDays": 14
  },
  "SendGrid": {
    "ApiKey": "${SENDGRID_API_KEY}",
    "FromEmail": "${SENDGRID_FROM_EMAIL}",
    "FromName": "KinCare"
  },
  "Broker": {
    "BaseUrl": "https://api.roundtriphealth.com",
    "ApiKey": "${ROUNDTRIP_API_KEY}",
    "ClientId": "${ROUNDTRIP_CLIENT_ID}",
    "ClientSecret": "${ROUNDTRIP_CLIENT_SECRET}",
    "Audience": "https://api.roundtriphealth.com",
    "OrganizationId": "${ROUNDTRIP_ORGANIZATION_ID}",
    "WebhookSecret": "${ROUNDTRIP_WEBHOOK_SECRET}"
  },
  "App": {
    "BaseUrl": "${KINCARE_APP_BASE_URL}"
  },
  "Splunk": {
    "HecUrl": "${SPLUNK_HEC_URL}",
    "HecToken": "${SPLUNK_HEC_TOKEN}"
  },
  "IpRateLimit": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "POST:/api/auth/login",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "POST:/api/onboarding/register",
        "Period": "1m",
        "Limit": 3
      },
      {
        "Endpoint": "POST:/webhook/twilio",
        "Period": "1m",
        "Limit": 60
      },
      {
        "Endpoint": "POST:/api/rides/location",
        "Period": "5s",
        "Limit": 1
      },
      {
        "Endpoint": "*",
        "Period": "1s",
        "Limit": 30
      }
    ]
  },
  "Cors": {
    "AllowedOrigins": ["${KINCARE_APP_BASE_URL}"]
  }
}
